# Copy to .env and fill in values:
#   cp .env.example .env

# --- Database ---
# Local Docker (see docker-compose.yml): Postgres on host port 5433
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/resume_interview
# Production (Neon): use your connection string; keep postgresql+asyncpg:// and drop sslmode if present

# --- Auth (Clerk) ---
CLERK_JWKS_URL=https://YOUR_INSTANCE.clerk.accounts.dev/.well-known/jwks.json

# --- OpenAI ---
OPENAI_API_KEY=sk-your-key-here

# --- Object storage (S3-compatible) ---
# Cloudflare R2 (production): leave R2_ENDPOINT empty and set account + keys + public URL
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_ENDPOINT=
R2_PUBLIC_URL=

# MinIO (local Docker): after `docker compose up`, use the defaults below (matches docker-compose.yml)
# R2_ACCESS_KEY_ID=minioadmin
# R2_SECRET_ACCESS_KEY=minioadmin
# R2_BUCKET_NAME=resume-interview
# R2_ENDPOINT=http://127.0.0.1:9000
# R2_PUBLIC_URL=http://127.0.0.1:9000/resume-interview
# R2_ACCOUNT_ID=   (leave empty when using R2_ENDPOINT)
